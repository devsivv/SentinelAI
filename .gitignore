# ======================================================
# Model Artifacts
#
# The models/ directory contains both production
# inference models (committed) and experimental
# trained weights (not committed).
#
# Rule: ignore everything, then explicitly un-ignore
# the exact production files needed at runtime.
# ======================================================

# Ignore all weight / artifact files by default
models/**/*.pkl
models/**/*.joblib
models/**/*.pt
models/**/*.pth
models/**/*.onnx
models/**/*.ckpt
models/**/*.npy
models/**/*_metrics.json
models/**/*_confusion_matrix.npy

# Production inference models — explicitly kept
!models/currency/currency_model_best.pth
!models/currency/mobilenet_v2.pt
!models/sms/sms_model.pkl
!models/sms/tfidf_vectorizer.pkl
!models/phishing/phishing_model.joblib
!models/phishing/phishing_model.pkl
!models/transactions/paysim_model.joblib
!models/transactions/xgb_model.pkl

# Always keep metadata and placeholder files
!models/**/class_names.json
!models/**/.gitkeep

# ======================================================
# Datasets
# Raw datasets are large binary/tabular files.
# Only notebooks and .gitkeep placeholders are committed.
# ======================================================

# Tabular data
datasets/**/*.csv
datasets/**/*.json
datasets/**/*.xlsx
datasets/**/*.xls
datasets/**/*.parquet
datasets/**/*.zip
datasets/**/*.tar
datasets/**/*.gz

# Image data
datasets/**/*.jpg
datasets/**/*.jpeg
datasets/**/*.png
datasets/**/*.bmp
datasets/**/*.tif
datasets/**/*.tiff
datasets/**/*.webp

# Dataset sub-folders
datasets/**/data/
datasets/**/Features/
datasets/**/*_Features/
datasets/**/images/

!datasets/**/.gitkeep

# ======================================================
# Experiment Outputs
# ======================================================

experiments/**/checkpoints/
experiments/**/runs/
experiments/**/logs/
experiments/**/outputs/

