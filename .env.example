# ============================================================
# SentinelAI — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
#   cp .env.example .env
# ============================================================


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=SentinelAI
APP_ENV=development         # development | production


# ------------------------------------------------------------
# API Server (read by core/config.py AppConfig)
# ------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000

# Comma-separated list of allowed CORS origins.
# Update this if your frontend runs on a different port or domain.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
# Root log level for the API layer and orchestrator.
LOG_LEVEL=INFO


# ------------------------------------------------------------
# Scam Communication Agent (prefix: SCAM_COMM_)
# Override model paths if you place artifacts in custom locations.
# Defaults point to models/sms/ and models/phishing/ under PROJECT_ROOT.
# ------------------------------------------------------------
# SCAM_COMM_SMS_MODEL_PATH=/absolute/path/to/sms_model.pkl
# SCAM_COMM_TFIDF_PATH=/absolute/path/to/tfidf_vectorizer.pkl
# SCAM_COMM_PHISHING_MODEL_PATH=/absolute/path/to/phishing_model.joblib
# SCAM_COMM_SMS_CONFIDENCE_THRESHOLD=0.70
# SCAM_COMM_URL_CONFIDENCE_THRESHOLD=0.70
# SCAM_COMM_LOG_LEVEL=INFO
# SCAM_COMM_LOG_DIR=/path/to/logs/agents


# ------------------------------------------------------------
# Fraud Agent (prefix: FRAUD_)
# Override model paths if you place artifacts in custom locations.
# Default points to models/transactions/paysim_model.joblib under PROJECT_ROOT.
# ------------------------------------------------------------
# FRAUD_MODEL_PATH=/absolute/path/to/paysim_model.joblib
# FRAUD_LARGE_TRANSACTION_THRESHOLD=1200000.0
# FRAUD_CONFIDENCE_THRESHOLD=0.70
# FRAUD_LOG_LEVEL=INFO
# FRAUD_LOG_DIR=/path/to/logs/agents


# ------------------------------------------------------------
# Database (PostgreSQL) — active from Sprint 09
# Read by core/config.py AppConfig as `database_url` (SecretStr).
#
# Format:
#   postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
#
# Special characters in passwords (e.g. @, /, :) must be
# percent-encoded.  Use Python to encode: urllib.parse.quote("my@pass", safe="")
# ------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:change_me@localhost:5432/sentinelai